#!/usr/bin/env bash
# Git pre-commit: UTF-8 チェック（*.md）→ version.txt バンプ（requires python3）。
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
python3 "$ROOT/scripts/check_staged_markdown_utf8.py"
VT="$ROOT/version.txt"
if [[ ! -f "$VT" ]]; then
  exit 0
fi
python3 "$ROOT/scripts/bump_version_txt.py" "$VT"
git add -- "$VT"
