{
  // ワークスペースをこのフォルダだけ開いたときの既定。既存ファイルは推測エンコーディングのまま
  "files.encoding": "utf8",
  "files.autoGuessEncoding": true,
  // Open in External App (YuTengjing.open-in-external-app)
  // Excel 2021: 本PCで EXCEL.EXE のパスを確認すること
  // 別PCや MSI 版ではパスが異なる場合がある（例: ...\Office16\EXCEL.EXE）
  "openInExternalApp.openMapper": [
    {
      "extensionName": "xlsx",
      "apps": [
        {
          "title": "Microsoft Excel 2021",
          "openCommand": "C:\\Program Files\\Microsoft Office\\root\\Office16\\EXCEL.EXE"
        }
      ]
    },
    {
      "extensionName": "xlsm",
      "apps": [
        {
          "title": "Microsoft Excel 2021",
          "openCommand": "C:\\Program Files\\Microsoft Office\\root\\Office16\\EXCEL.EXE"
        }
      ]
    }
  ]
}
