Private Function SafePersonalSheetName(ByVal baseName As String) As String
    Dim s As String
    s = "??l_" & Trim$(baseName)
    ' Excel ?V?[?g????g???????????????
    s = Replace(s, "\", "")
    s = Replace(s, "/", "")
    s = Replace(s, "?", "")
    s = Replace(s, "*", "")
    s = Replace(s, "[", "")
    s = Replace(s, "]", "")
    s = Replace(s, ":", "")
    If Len(s) = 0 Then s = "??l_Sheet"
    If Len(s) > 31 Then s = Left$(s, 31)
    SafePersonalSheetName = s
End Function

