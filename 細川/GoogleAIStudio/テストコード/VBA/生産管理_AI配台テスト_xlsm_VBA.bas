Private Sub ApplyFontToAllSheetCells(ByVal fontName As String, ByRef skippedOut As String)
    Dim ws As Worksheet
    Dim ur As Range
    Dim rangeErr As Boolean
    
    skippedOut = ""
    For Each ws In ThisWorkbook.Worksheets
        On Error Resume Next
        rangeErr = False
        Set ur = Nothing
        Set ur = ws.UsedRange
        If Err.Number <> 0 Then
            skippedOut = skippedOut & "?E" & ws.Name & "?iUsedRange: " & Err.Description & "?j" & vbCrLf
            Err.Clear
            rangeErr = True
        End If
        If Not rangeErr Then
            ur.Font.Name = fontName
            If Err.Number <> 0 Then
                skippedOut = skippedOut & "?E" & ws.Name & "?iFont.Name: " & Err.Description & "?j" & vbCrLf
                Err.Clear
            End If
        End If
        On Error GoTo 0
    Next ws
End Sub

