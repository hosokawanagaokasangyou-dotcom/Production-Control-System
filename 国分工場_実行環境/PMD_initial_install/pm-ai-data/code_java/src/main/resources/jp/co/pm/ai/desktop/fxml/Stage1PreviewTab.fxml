<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fillWidth="true" spacing="8.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="jp.co.pm.ai.desktop.Stage1PreviewTabController">
    <padding>
        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
    </padding>
    <Label fx:id="hintLabel" wrapText="true" />
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Label text="ファイル" />
        <TextField fx:id="pathField" HBox.hgrow="ALWAYS" />
        <Button fx:id="fromEnvButton" mnemonicParsing="false" onAction="#onFromEnvButtonAction" text="環境よりパス" />
        <Button fx:id="browseButton" mnemonicParsing="false" onAction="#onBrowseButtonAction" text="参照…" />
        <Button fx:id="loadButton" mnemonicParsing="false" onAction="#onLoadButtonAction" text="読込" />
    </HBox>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Label text="シート" />
        <TextField fx:id="sheetField" HBox.hgrow="ALWAYS" />
        <Label text="列幅(px)" />
        <TextField fx:id="colWidthField" maxWidth="72.0" prefWidth="72.0" promptText="112" />
        <Button mnemonicParsing="false" text="列フィルタ・並べ替え解除"
                onAction="#onClearColumnFiltersAction"/>
    </HBox>
    <HBox spacing="8.0" />
    <HBox fx:id="columnStripHostRow" alignment="CENTER_LEFT" spacing="8.0" style="-fx-alignment: CENTER_LEFT;">
        <HBox fx:id="columnStripHost" spacing="0.0" />
    </HBox>
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="データ行の高さ（一括）" />
        <Slider fx:id="stage1RowHeightSlider" blockIncrement="25.0" majorTickUnit="250.0" max="2000.0" min="50.0"
                prefWidth="240.0" showTickMarks="true" />
        <Label fx:id="stage1RowHeightPctLabel" minWidth="52.0" text="100%" />
        <CheckBox fx:id="stage1CellWrapCheck" mnemonicParsing="false" text="長い文字列を折り返す" />
    </HBox>
    <StackPane fx:id="spreadsheetHost" minHeight="240.0" VBox.vgrow="ALWAYS">
        <VBox.margin>
            <Insets bottom="8.0" left="8.0" right="8.0" />
        </VBox.margin>
    </StackPane>
</VBox>
