<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TableView?>

<!-- Layout for Scene Builder; long hint text set in controller (\u escapes). -->
<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jp.co.pm.ai.desktop.ExcludeRulesTabController">
    <center>
        <VBox spacing="8.0">
            <padding>
                <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
            </padding>
            <Label fx:id="hintLabel" wrapText="true"/>
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label text="パス"/>
                <TextField fx:id="pathField" HBox.hgrow="ALWAYS"/>
                <Button mnemonicParsing="false"
                        text="環境変数からパス"
                        onAction="#onFromEnvButtonAction"/>
                <Button mnemonicParsing="false" text="参照..."
                        onAction="#onPickButtonAction"/>
            </HBox>
            <HBox spacing="8.0">
                <Button mnemonicParsing="false" text="読込"
                        onAction="#onLoadButtonAction"/>
                <Button mnemonicParsing="false" text="保存"
                        onAction="#onSaveButtonAction"/>
                <Button mnemonicParsing="false" text="JSON 検証"
                        onAction="#onValidateButtonAction"/>
                <Button mnemonicParsing="false" text="整形"
                        onAction="#onFormatButtonAction"/>
            </HBox>
            <SplitPane fx:id="editorSplit" dividerPositions="0.48" orientation="VERTICAL" VBox.vgrow="ALWAYS">
                <VBox spacing="6.0">
                    <padding>
                        <Insets bottom="4.0" left="0.0" right="0.0" top="0.0"/>
                    </padding>
                    <HBox spacing="8.0">
                        <Button mnemonicParsing="false" text="行を追加"
                                onAction="#onAddRowButtonAction"/>
                        <Button mnemonicParsing="false" text="行を削除"
                                onAction="#onRemoveRowButtonAction"/>
                        <Button mnemonicParsing="false" text="JSON→表"
                                onAction="#onJsonToTableButtonAction"/>
                        <Button mnemonicParsing="false" text="表→JSON"
                                onAction="#onTableToJsonButtonAction"/>
                    </HBox>
                    <TableView fx:id="rulesTable" editable="true" minHeight="160.0" VBox.vgrow="ALWAYS"/>
                </VBox>
                <TextArea fx:id="bodyArea" prefRowCount="12" wrapText="false"/>
            </SplitPane>
        </VBox>
    </center>
</BorderPane>
