{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.pm-ai/schemas/column-manifest-v1.json",
  "title": "Column manifest instance (schema.json)",
  "description": "Column manifest per plan IPC template. headerKey must match Python PLAN_* / TASK_* string values in _core.py.",
  "type": "object",
  "required": ["schemaVersion", "sheets"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$",
      "description": "Manifest format version starting at 1.0"
    },
    "document": {
      "type": "string",
      "description": "Optional document id e.g. dispatch-plan-column-manifest"
    },
    "sheets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "excelSheetName", "columns"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Stable id for code and settings"
          },
          "excelSheetName": {
            "type": "string",
            "minLength": 1,
            "description": "Excel sheet name for openpyxl / POI"
          },
          "columns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["headerKey", "javaProperty", "valueKind", "nullable"],
              "properties": {
                "headerKey": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Column header string matching _core.py constants"
                },
                "pythonConstantHint": {
                  "type": "string",
                  "description": "PLAN_* / TASK_* name for docs and validation"
                },
                "javaProperty": {
                  "type": "string",
                  "pattern": "^[a-z][a-zA-Z0-9]*$",
                  "description": "Java property name camelCase"
                },
                "valueKind": {
                  "type": "string",
                  "enum": [
                    "string",
                    "integer",
                    "decimal",
                    "date",
                    "datetime",
                    "boolean"
                  ],
                  "description": "POI boundary conversion hint"
                },
                "nullable": {
                  "type": "boolean",
                  "description": "Whether null is allowed"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
