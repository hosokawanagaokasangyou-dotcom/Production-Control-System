<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>jp.co.pm.ai</groupId>
  <artifactId>production-control-desktop</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <packaging>jar</packaging>
  <name>production-control-desktop</name>
  <description>JavaFX UI and Python planning_core bridge (see Production-Control-System/plan/ for migration plan)</description>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <!-- OpenJFX 26.x と揃える（JDK は 26 以上を推奨） -->
    <maven.compiler.release>26</maven.compiler.release>
    <!-- package_app.ps1: javafx.version の OpenJFX Windows win.jar を Maven Central から取得して package_input に同期 -->
    <javafx.version>26.0.1</javafx.version>
    <controlsfx.version>11.2.3</controlsfx.version>
    <poi.version>5.5.1</poi.version>
    <jfreechart.version>1.5.4</jfreechart.version>
    <jackson.version>2.21.3</jackson.version>
    <junit.version>5.12.2</junit.version>
    <!-- poi-ooxml が運ぶ log4j-api と同一に揃える（log4j-core 無しだと API がプロバイダ不足になり ERROR になる） -->
    <log4j.version>2.24.3</log4j.version>
    <!-- NGCanvas + Prism GPU で RTTexture が null（NPE）になる環境があるため既定は sw。GPU 試行は pm.ai.javafx.prism.gpu を参照 -->
    <javafx.prism.order>sw</javafx.prism.order>
    <!-- javafx:run / exec:exec@pm-ai-desktop / jpackage のヒープ上限（既定 3g。増やす例: -Djvm.max.heap=8g） -->
    <jvm.max.heap>4g</jvm.max.heap>
    <!-- javafx:run / exec:exec@pm-ai-desktop / jpackage の初期ヒープ（-Xms。package_app.ps1 も同じ値を参照） -->
    <jvm.initial.heap>4g</jvm.initial.heap>
    <!-- package_app.ps1: Windows embeddable Python（amd64）。code/python/pyproject.toml の requires-python と整合 -->
    <pm.ai.bundle.python.embed.version>3.14.4</pm.ai.bundle.python.embed.version>
    <!-- package_app.ps1: Temurin JDK zip for jpackage runtime-image (Windows x64). Empty = Adoptium API -->
    <pm.ai.bundle.jdk.windows.release>${maven.compiler.release}</pm.ai.bundle.jdk.windows.release>
    <pm.ai.bundle.jdk.windows.zip.url></pm.ai.bundle.jdk.windows.zip.url>
  </properties>

  <dependencies>
    <dependency>
      <groupId>org.controlsfx</groupId>
      <artifactId>controlsfx</artifactId>
      <version>${controlsfx.version}</version>
    </dependency>
    <dependency>
      <groupId>org.apache.poi</groupId>
      <artifactId>poi-ooxml</artifactId>
      <version>${poi.version}</version>
    </dependency>
    <dependency>
      <groupId>org.apache.logging.log4j</groupId>
      <artifactId>log4j-core</artifactId>
      <version>${log4j.version}</version>
    </dependency>
    <dependency>
      <groupId>org.jfree</groupId>
      <artifactId>jfreechart</artifactId>
      <version>${jfreechart.version}</version>
    </dependency>
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
      <version>${jackson.version}</version>
    </dependency>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <profiles>
    <profile>
      <id>javafx-linux</id>
      <activation>
        <os>
          <name>Linux</name>
        </os>
      </activation>
      <dependencies>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-controls</artifactId>
          <version>${javafx.version}</version>
          <classifier>linux</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-swing</artifactId>
          <version>${javafx.version}</version>
          <classifier>linux</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-graphics</artifactId>
          <version>${javafx.version}</version>
          <classifier>linux</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-base</artifactId>
          <version>${javafx.version}</version>
          <classifier>linux</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-fxml</artifactId>
          <version>${javafx.version}</version>
          <classifier>linux</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-web</artifactId>
          <version>${javafx.version}</version>
          <classifier>linux</classifier>
        </dependency>
      </dependencies>
    </profile>
    <profile>
      <id>javafx-win</id>
      <activation>
        <os>
          <family>windows</family>
        </os>
      </activation>
      <dependencies>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-controls</artifactId>
          <version>${javafx.version}</version>
          <classifier>win</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-swing</artifactId>
          <version>${javafx.version}</version>
          <classifier>win</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-graphics</artifactId>
          <version>${javafx.version}</version>
          <classifier>win</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-base</artifactId>
          <version>${javafx.version}</version>
          <classifier>win</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-fxml</artifactId>
          <version>${javafx.version}</version>
          <classifier>win</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-web</artifactId>
          <version>${javafx.version}</version>
          <classifier>win</classifier>
        </dependency>
      </dependencies>
    </profile>
    <profile>
      <id>javafx-mac</id>
      <activation>
        <os>
          <family>mac</family>
        </os>
      </activation>
      <dependencies>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-controls</artifactId>
          <version>${javafx.version}</version>
          <classifier>mac</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-swing</artifactId>
          <version>${javafx.version}</version>
          <classifier>mac</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-graphics</artifactId>
          <version>${javafx.version}</version>
          <classifier>mac</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-base</artifactId>
          <version>${javafx.version}</version>
          <classifier>mac</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-fxml</artifactId>
          <version>${javafx.version}</version>
          <classifier>mac</classifier>
        </dependency>
        <dependency>
          <groupId>org.openjfx</groupId>
          <artifactId>javafx-web</artifactId>
          <version>${javafx.version}</version>
          <classifier>mac</classifier>
        </dependency>
      </dependencies>
    </profile>
  </profiles>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <release>${maven.compiler.release}</release>
          <encoding>${project.build.sourceEncoding}</encoding>
          <!-- リフレクションでパラメータ名を利用する場合に有利 -->
          <parameters>true</parameters>
          <compilerArgs>
            <arg>-encoding</arg>
            <arg>UTF-8</arg>
          </compilerArgs>
        </configuration>
      </plugin>

      <!-- === 今回追加した部分（WSLドライブのJAR作成エラー回避） === -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.4.1</version>
        <configuration>
          <archive>
            <addMavenDescriptor>false</addMavenDescriptor>
          </archive>
        </configuration>
      </plugin>
      <!-- ========================================================= -->

      <!-- 開発時のクイック起動: mvn javafx:run -->
      <plugin>
        <groupId>org.openjfx</groupId>
        <artifactId>javafx-maven-plugin</artifactId>
        <version>0.0.8</version>
        <configuration>
          <mainClass>jp.co.pm.ai.desktop.PmAiFxApp</mainClass>
          <options>
            <option>-Dfile.encoding=UTF-8</option>
            <option>-Dprism.order=${javafx.prism.order}</option>
            <option>-Xms${jvm.initial.heap}</option>
            <option>-Xmx${jvm.max.heap}</option>
            <option>-XX:+HeapDumpOnOutOfMemoryError</option>
            <option>-XX:+UseStringDeduplication</option>
            <option>--enable-native-access=javafx.graphics</option>
          </options>
        </configuration>
      </plugin>

      <!-- jpackage や WebView 利用時など、モジュールパスに jdk.jsobject / jdk.xml.dom を明示したい場合は exec:exec@pm-ai-desktop -->
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.6.3</version>
        <configuration>
          <classpathScope>compile</classpathScope>
          <executable>java</executable>
          <longModulepath>false</longModulepath>
        </configuration>
        <executions>
          <execution>
            <id>pm-ai-desktop</id>
            <goals>
              <goal>exec</goal>
            </goals>
            <phase>none</phase>
            <configuration>
              <arguments>
                <argument>-Dfile.encoding=UTF-8</argument>
                <argument>-Xms${jvm.initial.heap}</argument>
                <argument>-Xmx${jvm.max.heap}</argument>
                <argument>-XX:+HeapDumpOnOutOfMemoryError</argument>
                <argument>-XX:+UseStringDeduplication</argument>
                <argument>-Dprism.order=${javafx.prism.order}</argument>
                <argument>--module-path</argument>
                <argument>${pm.ai.openjfx.module.path}</argument>
                <argument>--add-modules</argument>
                <argument>javafx.controls,javafx.fxml,javafx.graphics,javafx.base,javafx.swing,javafx.web,jdk.jsobject,jdk.xml.dom</argument>
                <argument>--add-opens=javafx.base/com.sun.javafx.event=ALL-UNNAMED</argument>
                <argument>--add-opens=javafx.controls/javafx.scene.control.skin=ALL-UNNAMED</argument>
                <argument>--add-exports=javafx.controls/com.sun.javafx.scene.control.behavior=ALL-UNNAMED</argument>
                <argument>--enable-native-access=javafx.graphics</argument>
                <argument>-classpath</argument>
                <argument>${project.build.outputDirectory}${path.separator}${pm.ai.non.openjfx.classpath}</argument>
                <argument>jp.co.pm.ai.desktop.PmAiFxApp</argument>
              </arguments>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.5.4</version>
        <configuration>
          <useModulePath>false</useModulePath>
        </configuration>
      </plugin>
      <!-- jpackage（Windows package_app.ps1）が classpath 入力を組むため package 時に依存 JAR を target/dependency に複製 -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-dependency-plugin</artifactId>
        <version>3.8.1</version>
        <executions>
          <execution>
            <id>pm-ai-openjfx-module-path</id>
            <phase>validate</phase>
            <goals>
              <goal>build-classpath</goal>
            </goals>
            <configuration>
              <includeScope>compile</includeScope>
              <includeGroupIds>org.openjfx</includeGroupIds>
              <pathSeparator>${path.separator}</pathSeparator>
              <outputProperty>pm.ai.openjfx.module.path</outputProperty>
            </configuration>
          </execution>
          <execution>
            <id>pm-ai-non-openjfx-classpath</id>
            <phase>validate</phase>
            <goals>
              <goal>build-classpath</goal>
            </goals>
            <configuration>
              <includeScope>compile</includeScope>
              <excludeGroupIds>org.openjfx</excludeGroupIds>
              <pathSeparator>${path.separator}</pathSeparator>
              <outputProperty>pm.ai.non.openjfx.classpath</outputProperty>
            </configuration>
          </execution>
          <execution>
            <id>copy-runtime-deps-for-jpackage</id>
            <phase>package</phase>
            <goals>
              <goal>copy-dependencies</goal>
            </goals>
            <configuration>
              <outputDirectory>${project.build.directory}/dependency</outputDirectory>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>