{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.pm-ai/schemas/ipc-line-v1.json",
  "title": "Python stdout NDJSON line (one JSON object per line)",
  "description": "Matches plan section IPC template (draft). UTF-8, newline LF only.",
  "oneOf": [
    { "$ref": "#/$defs/ipcProgress" },
    { "$ref": "#/$defs/ipcLog" },
    { "$ref": "#/$defs/ipcValidationError" },
    { "$ref": "#/$defs/ipcFatalError" },
    { "$ref": "#/$defs/ipcDone" },
    { "$ref": "#/$defs/ipcPing" }
  ],
  "$defs": {
    "ipcCommon": {
      "type": "object",
      "required": ["schemaVersion", "type", "ts"],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "1.0",
          "description": "IPC message format version"
        },
        "ts": {
          "type": "string",
          "description": "ISO-8601 with timezone recommended, e.g. 2026-05-02T13:00:00+09:00"
        }
      },
      "additionalProperties": true
    },
    "ipcProgress": {
      "allOf": [
        { "$ref": "#/$defs/ipcCommon" },
        {
          "type": "object",
          "required": ["type", "step", "label", "current"],
          "properties": {
            "type": { "const": "progress" },
            "step": { "type": "string", "minLength": 1 },
            "label": { "type": "string", "minLength": 1 },
            "current": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 },
            "percent": { "type": "number", "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": true
        }
      ]
    },
    "ipcLog": {
      "allOf": [
        { "$ref": "#/$defs/ipcCommon" },
        {
          "type": "object",
          "required": ["type", "level", "message"],
          "properties": {
            "type": { "const": "log" },
            "level": {
              "type": "string",
              "enum": ["DEBUG", "INFO", "WARN", "ERROR"]
            },
            "message": { "type": "string", "minLength": 1 },
            "logger": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    },
    "ipcValidationError": {
      "allOf": [
        { "$ref": "#/$defs/ipcCommon" },
        {
          "type": "object",
          "required": ["type", "exitCode", "code", "message", "remediation"],
          "properties": {
            "type": { "const": "validation_error" },
            "exitCode": { "type": "integer", "const": 3 },
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 },
            "remediation": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            },
            "detail": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": true
        }
      ]
    },
    "ipcFatalError": {
      "allOf": [
        { "$ref": "#/$defs/ipcCommon" },
        {
          "type": "object",
          "required": ["type", "exitCode", "code", "message", "remediation"],
          "properties": {
            "type": { "const": "fatal_error" },
            "exitCode": { "type": "integer", "const": 2 },
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 },
            "remediation": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            },
            "cause": { "type": "string" },
            "detail": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": true
        }
      ]
    },
    "ipcDone": {
      "allOf": [
        { "$ref": "#/$defs/ipcCommon" },
        {
          "type": "object",
          "required": ["type", "exitCode", "outputPaths"],
          "properties": {
            "type": { "const": "done" },
            "exitCode": { "type": "integer", "const": 0 },
            "outputPaths": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "summary": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    },
    "ipcPing": {
      "allOf": [
        { "$ref": "#/$defs/ipcCommon" },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "ping" },
            "label": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    }
  }
}
