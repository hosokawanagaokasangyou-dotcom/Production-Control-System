<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- &#35336;&#30011;&#32080;&#26524; JSON &#12499;&#12517;&#12540;&#12450;&#65288;&#20837;&#12428;&#23376;&#12479;&#12502;&#65289; {@link PlanResultViewerTabController} -->
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="jp.co.pm.ai.desktop.PlanResultViewerTabController"
      fillWidth="true" spacing="8.0" styleClass="pm-plan-result-viewer">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
    </padding>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Button fx:id="reloadButton" mnemonicParsing="false" text="&#x518d;&#x8aad;&#x307f;"
                onAction="#onReloadButtonAction"/>
        <Button fx:id="syncLatestButton" mnemonicParsing="false"
                text="&#x6700;&#x65b0;JSON&#x3092;&#x691c;&#x7d22;"
                onAction="#onSyncLatestButtonAction"/>
    </HBox>
    <Label text="production_plan_multi_day*.json"/>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <TextField fx:id="planJsonField" prefWidth="560.0" promptText="*.json"/>
        <Button fx:id="browsePlanButton" mnemonicParsing="false" text="&#x53c2;&#x7167;..."
                onAction="#onBrowsePlanJsonAction"/>
    </HBox>
    <Label text="member_schedule*.json"/>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <TextField fx:id="memberJsonField" prefWidth="560.0" promptText="*.json"/>
        <Button fx:id="browseMemberButton" mnemonicParsing="false" text="&#x53c2;&#x7167;..."
                onAction="#onBrowseMemberJsonAction"/>
    </HBox>
    <Label fx:id="statusLabel" wrapText="true"/>
    <Label fx:id="hintLabel" wrapText="true"/>
    <BorderPane fx:id="contentPane" minHeight="320.0" VBox.vgrow="ALWAYS"/>
</VBox>
