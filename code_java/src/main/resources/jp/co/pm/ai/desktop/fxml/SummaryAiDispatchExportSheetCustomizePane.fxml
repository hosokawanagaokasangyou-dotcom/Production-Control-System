<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jp.co.pm.ai.desktop.SummaryAiDispatchExportSheetCustomizePaneController">
    <padding>
        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0"/>
    </padding>
    <center>
        <VBox spacing="10.0">
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label text="見出し列数（横スクロール固定）:"/>
                <Spinner fx:id="frozenColumnSpinner" editable="true" prefWidth="80.0"/>
                <Label style="-fx-text-fill: -fx-mid-text-color" wrapText="true" maxWidth="480"
                       text="先頭 N 列と 1 行目をウィンドウ固定します。既定: メイン比較7・配台5・アラジン7。"/>
            </HBox>
            <Label style="-fx-font-weight: bold" text="非日付列の並び（上から優先。日付列は自動で末尾）"/>
            <ListView fx:id="columnOrderList" prefHeight="220.0"/>
            <HBox spacing="8.0">
                <Button mnemonicParsing="false" onAction="#onMoveUpAction" text="上へ"/>
                <Button mnemonicParsing="false" onAction="#onMoveDownAction" text="下へ"/>
                <Button mnemonicParsing="false" onAction="#onImportFromUiAction" text="納期管理ビューから取り込む"/>
                <Button mnemonicParsing="false" onAction="#onClearColumnOrderAction" text="並びをクリア"/>
                <Button mnemonicParsing="false" onAction="#onSaveSheetAction" text="このシートを保存"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
