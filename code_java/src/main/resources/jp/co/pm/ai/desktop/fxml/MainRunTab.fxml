<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Labels/buttons: numeric char refs (ASCII-safe source file). -->
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jp.co.pm.ai.desktop.MainRunTabController">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0"/>
    </padding>
    <top>
        <VBox fillWidth="true" spacing="8.0">
            <GridPane hgap="8.0" vgap="8.0">
                <padding>
                    <Insets bottom="0.0" left="12.0" right="0.0" top="12.0"/>
                </padding>
                <children>
                    <!-- workbookField / pythonExeField / scriptDirField: session + env merge fallback (hidden; edit on &#x74b0;&#x5883;&#x5909;&#x6570; tab) -->
                    <HBox spacing="8.0" GridPane.columnIndex="1" GridPane.columnSpan="2"
                          GridPane.rowIndex="0">
                        <Button fx:id="stage1RunButton" mnemonicParsing="false"
                                text="&#x6bb5;&#x968e;1 &#x5b9f;&#x884c;"
                                onAction="#onStage1RunButtonAction"/>
                        <Button fx:id="stage2RunButton" mnemonicParsing="false"
                                text="&#x6bb5;&#x968e;2 &#x5b9f;&#x884c;"
                                onAction="#onStage2RunButtonAction"/>
                    </HBox>
                    <Label text="&#x6bb5;&#x968e;2 production_plan&#xff08;&#x6700;&#x65b0;&#xff09;"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <HBox spacing="8.0" GridPane.columnIndex="1" GridPane.columnSpan="2"
                          GridPane.rowIndex="1">
                        <TextField fx:id="stage2ProductionPlanField" editable="false"
                                   maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                        <Button mnemonicParsing="false"
                                text="&#x30a8;&#x30af;&#x30bb;&#x30eb;&#x3092;&#x958b;&#x304f;"
                                onAction="#onOpenStage2ProductionPlanAction"/>
                    </HBox>
                    <Label text="&#x6bb5;&#x968e;2 member_schedule&#xff08;&#x6700;&#x65b0;&#xff09;"
                           GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <HBox spacing="8.0" GridPane.columnIndex="1" GridPane.columnSpan="2"
                          GridPane.rowIndex="2">
                        <TextField fx:id="stage2MemberScheduleField" editable="false"
                                   maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                        <Button mnemonicParsing="false"
                                text="&#x30a8;&#x30af;&#x30bb;&#x30eb;&#x3092;&#x958b;&#x304f;"
                                onAction="#onOpenStage2MemberScheduleAction"/>
                    </HBox>
                </children>
            </GridPane>
            <HBox visible="false" managed="false" spacing="0.0">
                <TextField fx:id="workbookField" prefWidth="1.0"/>
                <TextField fx:id="pythonExeField" prefWidth="1.0"/>
                <TextField fx:id="scriptDirField" prefWidth="1.0"/>
            </HBox>
            <Label text="log (stdout+stderr merged)"/>
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label text="&#x30d5;&#x30a3;&#x30eb;&#x30bf;"/>
                <ComboBox fx:id="logFilterCombo" prefWidth="160.0"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label text="&#x30d5;&#x30a9;&#x30f3;&#x30c8;"/>
                <ComboBox fx:id="logFontFamilyCombo" prefWidth="260.0"/>
                <Label text="&#x30b5;&#x30a4;&#x30ba;"/>
                <ComboBox fx:id="logFontSizeCombo" prefWidth="88.0"/>
                <Button fx:id="copyAllLogButton" mnemonicParsing="false"
                        text="&#x5168;&#x30ed;&#x30b0;&#x3092;&#x30b3;&#x30d4;&#x30fc;"
                        onAction="#onCopyAllLogButtonAction"/>
                <Button fx:id="clearLogButton" mnemonicParsing="false"
                        text="&#x30ed;&#x30b0;&#x3092;&#x30af;&#x30ea;&#x30a2;"
                        onAction="#onClearLogButtonAction"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <ListView fx:id="logListView" minHeight="160.0" prefHeight="240.0"
                  styleClass="pm-log-view"/>
    </center>
    <bottom>
        <Label fx:id="statusLabel"
               text="exit: n/a &#x2014; 0=OK / 1=error / 2=fatal / 3=PlanningValidationError / 9=cancel">
            <BorderPane.margin>
                <Insets top="8.0"/>
            </BorderPane.margin>
        </Label>
    </bottom>
</BorderPane>
