<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Dynamic table columns remain in {@link PlanInputTabController}. -->
<VBox xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="jp.co.pm.ai.desktop.PlanInputTabController" fillWidth="true" spacing="8.0">
    <padding>
        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0"/>
    </padding>
    <GridPane hgap="8.0" vgap="8.0">
        <columnConstraints>
            <ColumnConstraints hgrow="NEVER" minWidth="-Infinity"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="100.0"/>
            <ColumnConstraints hgrow="NEVER" minWidth="-Infinity"/>
        </columnConstraints>
        <Label text="&#x30d5;&#x30a1;&#x30a4;&#x30eb;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="pathField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Button fx:id="browseButton" mnemonicParsing="false" text="&#x53c2;&#x7167;&#x2026;"
                onAction="#onBrowseButtonAction"
                GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <Label text="&#x30b7;&#x30fc;&#x30c8;&#x540d;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="sheetField" GridPane.columnIndex="1" GridPane.columnSpan="2"
                   GridPane.rowIndex="1"/>
    </GridPane>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Button fx:id="loadButton" mnemonicParsing="false" text="&#x8aad;&#x8fbc;"
                onAction="#onLoadButtonAction"/>
        <Button fx:id="saveButton" mnemonicParsing="false" text="&#x4fdd;&#x5b58;"
                onAction="#onSaveButtonAction"/>
        <Button fx:id="addRowButton" mnemonicParsing="false" text="&#x884c;&#x8ffd;&#x52a0;"
                onAction="#onAddRowButtonAction"/>
        <Button fx:id="removeRowsButton" mnemonicParsing="false" text="&#x884c;&#x524a;&#x9664;"
                onAction="#onRemoveRowsButtonAction"/>
    </HBox>
    <HBox fx:id="columnStripHostRow" alignment="CENTER_LEFT" spacing="8.0"
          style="-fx-alignment: CENTER_LEFT;">
        <HBox fx:id="columnStripHost" spacing="0.0"/>
        <Label text="&#x65e2;&#x5b9a;&#x5217;&#x5e45;(px)"/>
        <TextField fx:id="colWidthField" maxWidth="72.0" prefWidth="72.0" promptText="112"/>
    </HBox>
    <Label fx:id="hintLabel" wrapText="true"/>
    <TableView fx:id="table" minHeight="240.0" VBox.vgrow="ALWAYS">
        <VBox.margin>
            <Insets bottom="8.0" left="8.0" right="8.0"/>
        </VBox.margin>
    </TableView>
</VBox>
