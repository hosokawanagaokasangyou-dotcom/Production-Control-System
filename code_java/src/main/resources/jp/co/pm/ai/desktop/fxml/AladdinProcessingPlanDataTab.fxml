<?xml version="1.0" encoding="UTF-8"?>

<!-- ASCII + &#x....; のみ（CP932 マウントでも JavaFX が文字化けしない）。 -->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="jp.co.pm.ai.desktop.AladdinProcessingPlanDataTabController"
      fillWidth="true" spacing="8.0" maxHeight="Infinity">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
    </padding>
    <!-- 折りたたみ: 操作・ソース（両ペイン同時展開可 / Accordion とは別） -->
    <TitledPane animated="true" expanded="true"
                text="&#x64cd;&#x4f5c;&#x30fb;&#x30bd;&#x30fc;&#x30b9;">
        <content>
            <VBox fillWidth="true" spacing="8.0">
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <padding>
                        <Insets bottom="4.0"/>
                    </padding>
                    <Button mnemonicParsing="false"
                            text="&#x5217;&#x30d5;&#x30a3;&#x30eb;&#x30bf;&#x30fb;&#x4e26;&#x3079;&#x66ff;&#x3048;&#x89e3;&#x9664;"
                            onAction="#onClearColumnFiltersAction"/>
                    <Label fx:id="statusLabel"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <Label text="&#x30bd;&#x30fc;&#x30b9;&#x30d5;&#x30a9;&#x30eb;&#x30c0;"/>
                    <Label fx:id="dirLabel" wrapText="true"/>
                </HBox>
                <Label fx:id="pathLabel" wrapText="true"/>
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <Label text="Excel &#x30b7;&#x30fc;&#x30c8;"/>
                    <ComboBox fx:id="sheetCombo" prefWidth="280.0"/>
                </HBox>
                <Label fx:id="hintLabel" wrapText="true"/>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="&#x30c7;&#x30fc;&#x30bf;&#x884c;&#x306e;&#x9ad8;&#x3055;&#xff08;&#x4e00;&#x62ec;&#xff09;"/>
                    <Slider fx:id="rowHeightSlider" blockIncrement="25.0" majorTickUnit="250.0" max="2000.0"
                            min="50.0" prefWidth="240.0" showTickMarks="true"/>
                    <Label fx:id="rowHeightPctLabel" minWidth="52.0" text="100%"/>
                    <CheckBox fx:id="cellWrapCheck" mnemonicParsing="false"
                              text="&#x9577;&#x3044;&#x6587;&#x5b57;&#x5217;&#x3092;&#x6298;&#x308a;&#x8fd4;&#x3059;"/>
                </HBox>
                <HBox fx:id="columnStripHost" spacing="0.0"/>
            </VBox>
        </content>
    </TitledPane>
    <TitledPane animated="true" expanded="true" maxHeight="Infinity"
                text="&#x30c7;&#x30fc;&#x30bf;&#x8868;" VBox.vgrow="ALWAYS">
        <content>
            <VBox fillWidth="true">
                <StackPane fx:id="spreadsheetHost" minHeight="240.0" VBox.vgrow="ALWAYS"/>
            </VBox>
        </content>
    </TitledPane>
</VBox>
