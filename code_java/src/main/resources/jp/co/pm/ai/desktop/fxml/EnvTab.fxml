<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Hint and button captions are set in EnvTabController (\u escapes) for encoding safety. -->
<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jp.co.pm.ai.desktop.EnvTabController">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
    </padding>
    <center>
        <TabPane fx:id="envMainTabPane" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
            <tabs>
                <Tab fx:id="envVarsListTab" text="環境変数一覧" closable="false">
                    <content>
                        <VBox fillWidth="true" spacing="8.0">
                            <padding>
                                <Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
                            </padding>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label text="user.dir"/>
                                <Label fx:id="userDirLabel" wrapText="true" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <Label fx:id="hintLabel" wrapText="true"/>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label fx:id="envSearchLabel"/>
                                <TextField fx:id="envSearchField" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                                <Button mnemonicParsing="false" text="列フィルタ・並べ替え解除"
                                        onAction="#onClearColumnFiltersAction"/>
                            </HBox>
                            <HBox fx:id="columnStripHost" spacing="0.0"/>
                            <TableView fx:id="envTable" minHeight="180.0" prefHeight="260.0" VBox.vgrow="ALWAYS"/>
                            <HBox spacing="8.0">
                                <Button fx:id="addRowButton" mnemonicParsing="false"
                                        onAction="#onAddRowButtonAction"/>
                                <Button fx:id="delRowButton" mnemonicParsing="false"
                                        onAction="#onDelRowButtonAction"/>
                                <Button fx:id="addMissingEnvVarsButton" mnemonicParsing="false"
                                        onAction="#onAddMissingEnvVarsButtonAction"/>
                                <Button fx:id="resetEnvDefaultsButton" mnemonicParsing="false"
                                        onAction="#onResetEnvDefaultsButtonAction"/>
                                <Button fx:id="encryptGeminiCredentialsButton" mnemonicParsing="false"
                                        onAction="#onEncryptGeminiCredentialsAction"/>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>
                <Tab fx:id="dispatchGeminiModelsTab" text="配台 Gemini モデル優先" closable="false">
                    <content>
                        <VBox fillWidth="true" spacing="8.0">
                            <padding>
                                <Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
                            </padding>
                            <Label fx:id="dispatchGeminiHelpLabel" wrapText="true" maxWidth="Infinity"/>
                            <Label fx:id="dispatchGeminiPinnedWarning" wrapText="true" maxWidth="Infinity"
                                   style="-fx-text-fill: -fx-accent" managed="false" visible="false"/>
                            <ListView fx:id="dispatchGeminiModelListView" prefHeight="280.0" VBox.vgrow="ALWAYS"/>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label text="追加するモデル ID"/>
                                <TextField fx:id="dispatchGeminiModelAddField" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                           promptText="例: gemini-2.5-flash-lite"/>
                                <Button fx:id="dispatchGeminiAddButton" mnemonicParsing="false"
                                        onAction="#onDispatchGeminiAddModelAction" text="追加"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Button fx:id="dispatchGeminiMoveUpButton" mnemonicParsing="false"
                                        onAction="#onDispatchGeminiMoveUpAction" text="上へ"/>
                                <Button fx:id="dispatchGeminiMoveDownButton" mnemonicParsing="false"
                                        onAction="#onDispatchGeminiMoveDownAction" text="下へ"/>
                                <Button fx:id="dispatchGeminiRemoveButton" mnemonicParsing="false"
                                        onAction="#onDispatchGeminiRemoveAction" text="削除"/>
                                <Button fx:id="dispatchGeminiLoadDefaultsButton" mnemonicParsing="false"
                                        onAction="#onDispatchGeminiLoadDefaultsAction" text="コード既定を読み込み"/>
                                <Button fx:id="dispatchGeminiApplyToEnvButton" mnemonicParsing="false"
                                        onAction="#onDispatchGeminiApplyToEnvAction" text="環境変数へ書き込み"/>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>
