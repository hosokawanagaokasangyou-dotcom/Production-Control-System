<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- 設備ガント（時刻軸）を Canvas 帯で表示する独立タブ {@link EquipmentGanttGraphicTabController} -->
<VBox xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="jp.co.pm.ai.desktop.EquipmentGanttGraphicTabController"
      fillWidth="true" spacing="4.0" styleClass="pm-equipment-gantt-graphic-tab">
    <padding>
        <Insets bottom="8.0" left="12.0" right="12.0" top="8.0"/>
    </padding>
    <!-- 折りたたみ1つに JSON パス・説明・グラフィック調整スライダーを集約（見た目の段数を抑える） -->
    <Accordion fx:id="sourceAccordion" maxWidth="Infinity" VBox.vgrow="NEVER">
        <panes>
            <TitledPane fx:id="sourceTitledPane" animated="true"
                        text="ファイル・表示の調整"
                        expanded="true">
                <content>
                    <VBox fillWidth="true" spacing="8.0" styleClass="pm-plan-result-viewer-source-body">
                        <padding>
                            <Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <CheckBox fx:id="personBadgeShowCheckBox" mnemonicParsing="false"
                                      text="担当バッジを表示" selected="true"
                                      onAction="#onPersonBadgeShowAction"/>
                            <Button fx:id="reloadButton" mnemonicParsing="false" text="再読み"
                                    onAction="#onReloadButtonAction"/>
                            <Button fx:id="syncLatestButton" mnemonicParsing="false"
                                    text="最新JSONを検索"
                                    onAction="#onSyncLatestButtonAction"/>
                            <Label styleClass="pm-plan-result-viewer-hint-inline"
                                   text="production_plan_multi_day*.json の設備ガント系シートを表示"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <TextField fx:id="planJsonField" maxWidth="Infinity" prefWidth="560.0"
                                       promptText="*.json" HBox.hgrow="ALWAYS"/>
                            <Button fx:id="browsePlanButton" mnemonicParsing="false" text="参照..."
                                    onAction="#onBrowsePlanJsonAction"/>
                        </HBox>
                        <Label fx:id="hintLabel" wrapText="true"/>
                        <!-- グラフィック調整：FlowPane で折り返し、高さは行数に応じ自動 -->
                        <FlowPane hgap="8.0" maxWidth="Infinity"
                                  orientation="HORIZONTAL" vgap="6.0" VBox.vgrow="NEVER">
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label prefWidth="156.0" text="表示倍率"/>
                                <Slider fx:id="graphicZoomSlider" blockIncrement="5.0" max="200.0"
                                        min="50.0" prefWidth="118.0" showTickLabels="false"
                                        showTickMarks="false" value="100.0"/>
                                <Label fx:id="graphicZoomPercentLabel" text="100%"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label prefWidth="156.0" text="行の高さ"/>
                                <Slider fx:id="graphicRowHeightSlider" blockIncrement="5.0" max="200.0"
                                        min="50.0" prefWidth="96.0" showTickLabels="false"
                                        showTickMarks="false" value="100.0"/>
                                <Label fx:id="graphicRowHeightPctLabel" text="100%"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label prefWidth="156.0" text="見出し行の高さ"/>
                                <Slider fx:id="graphicHeaderHeightSlider" blockIncrement="5.0"
                                        max="200.0" min="50.0" prefWidth="96.0"
                                        showTickLabels="false" showTickMarks="false" value="100.0"/>
                                <Label fx:id="graphicHeaderHeightPctLabel" text="100%"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label prefWidth="156.0" text="時刻列幅"/>
                                <Slider fx:id="graphicSlotWidthSlider" blockIncrement="5.0"
                                        max="500.0" min="50.0" prefWidth="96.0"
                                        showTickLabels="false" showTickMarks="false" value="100.0"/>
                                <Label fx:id="graphicSlotWidthPctLabel" text="100%"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label prefWidth="156.0" text="Shift横スクロール"/>
                                <Slider fx:id="graphicShiftWheelHSlider" blockIncrement="5.0"
                                        max="1000.0" min="50.0" prefWidth="96.0"
                                        showTickLabels="false" showTickMarks="false" value="200.0"/>
                                <Label fx:id="graphicShiftWheelHLabel" text="200%"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label prefWidth="156.0" text="日付列幅"/>
                                <Slider fx:id="graphicDateColSlider" blockIncrement="1.0"
                                        max="220.0" min="0.0" prefWidth="88.0"
                                        showTickLabels="false" showTickMarks="false" value="0.0"/>
                                <Label fx:id="graphicDateColWidthLabel" text="自動"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label prefWidth="156.0" text="機械名列幅"/>
                                <Slider fx:id="graphicMachColSlider" blockIncrement="1.0"
                                        max="800.0" min="0.0" prefWidth="88.0"
                                        showTickLabels="false" showTickMarks="false" value="0.0"/>
                                <Label fx:id="graphicMachColWidthLabel" text="自動"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label prefWidth="156.0" text="工程名列幅"/>
                                <Slider fx:id="graphicProcColSlider" blockIncrement="1.0"
                                        max="800.0" min="0.0" prefWidth="88.0"
                                        showTickLabels="false" showTickMarks="false" value="0.0"/>
                                <Label fx:id="graphicProcColWidthLabel" text="自動"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label prefWidth="156.0" text="バー文字フォント"/>
                                <ComboBox fx:id="equipmentGraphicBarFontCombo" editable="false"
                                          prefWidth="140.0"/>
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="8.0">
                                <Label prefWidth="156.0" text="バー文字サイズ"/>
                                <Slider fx:id="graphicBarFontPctSlider" blockIncrement="5.0"
                                        max="200.0" min="50.0" prefWidth="96.0"
                                        showTickLabels="false" showTickMarks="false" value="100.0"/>
                                <Label fx:id="graphicBarFontPctLabel" text="100%"/>
                            </HBox>
                        </FlowPane>
                    </VBox>
                </content>
            </TitledPane>
        </panes>
    </Accordion>
    <Label fx:id="statusLabel" wrapText="true"/>
    <BorderPane fx:id="contentPane" minHeight="400.0" VBox.vgrow="ALWAYS"/>
</VBox>
