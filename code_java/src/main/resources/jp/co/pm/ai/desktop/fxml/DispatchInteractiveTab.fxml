<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="jp.co.pm.ai.desktop.DispatchInteractiveTabController"
      fillWidth="true" spacing="8.0">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
    </padding>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Button fx:id="loadButton" mnemonicParsing="false" text="&#x518d;&#x8aad;&#x307f;"
                onAction="#onLoadAction"/>
        <Button fx:id="saveButton" mnemonicParsing="false" text="&#x4fdd;&#x5b58; (JSON+xlsx)"
                onAction="#onSaveAction"/>
        <Button fx:id="reloadCalendarButton" mnemonicParsing="false" text="&#x6a5f;&#x68b0;&#x30ab;&#x30ec;&#x30f3;&#x30c0;&#x30fc;&#x518d;&#x8aad;&#x307f;"
                onAction="#onReloadCalendarAction"/>
        <ToggleButton fx:id="staffCheckToggle" mnemonicParsing="false"
                      text="&#x4eba;&#x54e1;&#x30c1;&#x30a7;&#x30c3;&#x30af;">
            <tooltip>
                <Tooltip text="&#x30de;&#x30b9;&#x30bf;&#x8aad;&#x8fbc;&#x30fb;&#x8a08;&#x753b;&#x7d50;&#x679c;&#x9023;&#x643a;&#x5f8c;&#x306b;OP/AS&#x4e0d;&#x8db3;&#x3092;&#x8868;&#x793a;&#x4e88;&#x5b9a;&#x3002;&#x73fe;&#x6642;&#x70b9;&#x306f;&#x30d2;&#x30f3;&#x30c8;&#x306e;&#x307f;&#x3002;"/>
            </tooltip>
        </ToggleButton>
        <Label fx:id="statusLabel"/>
    </HBox>
    <Label fx:id="jsonPathLabel" wrapText="true"/>
    <TabPane fx:id="innerTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab closable="false" text="&#x30bf;&#x30b9;&#x30af;&#xd7;&#x65e5;&#x4ed8;">
                <content>
                    <TableView fx:id="wideTable" prefHeight="480.0"/>
                </content>
            </Tab>
            <Tab closable="false" text="&#x5de5;&#x7a0b;+&#x6a5f;&#x68b0;&#xd7;&#x65e5;">
                <content>
                    <TableView fx:id="byDayTable" prefHeight="480.0"/>
                </content>
            </Tab>
        </tabs>
    </TabPane>
</VBox>
