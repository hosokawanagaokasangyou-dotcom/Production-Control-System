<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Layout for Scene Builder; long hint text set in controller (\u escapes). -->
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jp.co.pm.ai.desktop.ExcludeRulesTabController">
    <center>
        <VBox spacing="8.0">
            <padding>
                <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
            </padding>
            <Label fx:id="hintLabel" wrapText="true"/>
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label text="パス"/>
                <TextField fx:id="pathField" HBox.hgrow="ALWAYS"/>
                <Button fx:id="fromEnvButton" mnemonicParsing="false"
                        text="環境変数からパス"
                        onAction="#onFromEnvButtonAction"/>
                <Button fx:id="pickButton" mnemonicParsing="false" text="参照..."
                        onAction="#onPickButtonAction"/>
            </HBox>
            <HBox spacing="8.0">
                <Button fx:id="loadButton" mnemonicParsing="false" text="読込"
                        onAction="#onLoadButtonAction"/>
                <Button fx:id="saveButton" mnemonicParsing="false" text="保存"
                        onAction="#onSaveButtonAction"/>
                <Button fx:id="validateButton" mnemonicParsing="false" text="JSON 検証"
                        onAction="#onValidateButtonAction"/>
            </HBox>
            <TextArea fx:id="bodyArea" prefRowCount="18" wrapText="false" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
