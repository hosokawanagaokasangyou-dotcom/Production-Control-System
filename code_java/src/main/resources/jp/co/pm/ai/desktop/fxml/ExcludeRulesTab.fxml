<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Layout for Scene Builder; long hint text set in controller (\u escapes). -->
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jp.co.pm.ai.desktop.ExcludeRulesTabController">
    <center>
        <VBox spacing="8.0">
            <padding>
                <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
            </padding>
            <Label fx:id="hintLabel" wrapText="true"/>
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label text="&#x30d1;&#x30b9;"/>
                <TextField fx:id="pathField" HBox.hgrow="ALWAYS"/>
                <Button fx:id="fromEnvButton" mnemonicParsing="false"
                        text="&#x74b0;&#x5883;&#x5909;&#x6570;&#x304b;&#x3089;&#x30d1;&#x30b9;"
                        onAction="#onFromEnvButtonAction"/>
                <Button fx:id="pickButton" mnemonicParsing="false" text="&#x53c2;&#x7167;..."
                        onAction="#onPickButtonAction"/>
            </HBox>
            <HBox spacing="8.0">
                <Button fx:id="loadButton" mnemonicParsing="false" text="&#x8aad;&#x8fbc;"
                        onAction="#onLoadButtonAction"/>
                <Button fx:id="saveButton" mnemonicParsing="false" text="&#x4fdd;&#x5b58;"
                        onAction="#onSaveButtonAction"/>
                <Button fx:id="validateButton" mnemonicParsing="false" text="JSON &#x691c;&#x8a3c;"
                        onAction="#onValidateButtonAction"/>
            </HBox>
            <TextArea fx:id="bodyArea" prefRowCount="18" wrapText="false" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
