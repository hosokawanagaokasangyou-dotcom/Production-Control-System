<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="jp.co.pm.ai.desktop.MainShellTabOrganizerTabController"
      spacing="10.0">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <Label wrapText="true"
           text="メイン画面上部のタブ構成と見出し色を編集します。変更は「構成を適用」で反映されセッションに保存されます。"/>
    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <Tab text="ツリー・グループ" closable="false">
            <VBox spacing="10.0">
                <padding>
                    <Insets bottom="8.0" left="8.0" right="8.0" top="8.0"/>
                </padding>
                <Label wrapText="true"
                       text="ドラッグで行を移動できます（タブ行へ＝その位置の前へ挿入、グループ行へ＝グループの最後の子として格納）。複数選択して「選択をまとめてグループへ」でフォルダ化します。"/>
                <TreeView fx:id="treeView" VBox.vgrow="ALWAYS" prefHeight="280.0"/>
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <Label text="グループ名"/>
                    <TextField fx:id="groupNameField" prefWidth="280.0" promptText="グループ行を1つ選ぶと編集できます"
                               HBox.hgrow="ALWAYS"/>
                    <Button mnemonicParsing="false" onAction="#onApplyGroupName" text="名前を反映"/>
                </HBox>
                <HBox spacing="8.0">
                    <Button mnemonicParsing="false" onAction="#onAddGroup" text="空のグループを追加"/>
                    <Button mnemonicParsing="false" onAction="#onGroupSelection" text="選択をまとめてグループへ"/>
                </HBox>
            </VBox>
        </Tab>
        <Tab text="色・確定" closable="false">
            <VBox spacing="10.0">
                <padding>
                    <Insets bottom="8.0" left="8.0" right="8.0" top="8.0"/>
                </padding>
                <Label wrapText="true"
                       text="ツリーで行を選び、見出しに使う背景色を設定します（空にすると既定色に戻ります）。"/>
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <Label text="色"/>
                    <ColorPicker fx:id="colorPicker"/>
                    <Button mnemonicParsing="false" onAction="#onApplySelectedColor" text="選択に色を適用"/>
                    <Button mnemonicParsing="false" onAction="#onClearSelectedColor" text="選択の色を解除"/>
                </HBox>
                <HBox spacing="8.0">
                    <Button mnemonicParsing="false" onAction="#onResetFlat" text="フラット初期構成に戻す"/>
                    <Button defaultButton="true" mnemonicParsing="false" onAction="#onApplyLayout" text="構成を適用"/>
                </HBox>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
