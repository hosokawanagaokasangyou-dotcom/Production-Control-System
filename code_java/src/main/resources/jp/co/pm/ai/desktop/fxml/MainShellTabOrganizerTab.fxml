<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="jp.co.pm.ai.desktop.MainShellTabOrganizerTabController"
      spacing="10.0">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <Label wrapText="true"
           text="メイン画面上部のタブをグループ化したり、タブ見出しの色を付けたりできます。ツリーで複数選択し、「選択をまとめてグループへ」を押すと新しいグループに入ります。「構成を適用」でメインに反映・セッション保存されます。"/>
    <TreeView fx:id="treeView" VBox.vgrow="ALWAYS" prefHeight="320.0"/>
    <HBox spacing="8.0">
        <Button mnemonicParsing="false" onAction="#onAddGroup" text="グループを追加"/>
        <Button mnemonicParsing="false" onAction="#onGroupSelection" text="選択をまとめてグループへ"/>
        <Button mnemonicParsing="false" onAction="#onApplySelectedColor" text="選択に色を適用"/>
        <Button mnemonicParsing="false" onAction="#onClearSelectedColor" text="選択の色を解除"/>
    </HBox>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Label text="色"/>
        <ColorPicker fx:id="colorPicker"/>
    </HBox>
    <HBox spacing="8.0">
        <Button mnemonicParsing="false" onAction="#onResetFlat" text="フラット初期構成に戻す"/>
        <Button defaultButton="true" mnemonicParsing="false" onAction="#onApplyLayout" text="構成を適用"/>
    </HBox>
</VBox>
