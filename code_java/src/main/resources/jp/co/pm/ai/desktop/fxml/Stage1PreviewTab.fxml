<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="jp.co.pm.ai.desktop.Stage1PreviewTabController" fillWidth="true" spacing="8.0">
    <padding>
        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0"/>
    </padding>
    <Label fx:id="hintLabel" wrapText="true"/>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Label text="&#x30d5;&#x30a1;&#x30a4;&#x30eb;"/>
        <TextField fx:id="pathField" HBox.hgrow="ALWAYS"/>
        <Button fx:id="fromEnvButton" mnemonicParsing="false"
                text="&#x74b0;&#x5883;&#x3088;&#x308a;&#x30d1;&#x30b9;"
                onAction="#onFromEnvButtonAction"/>
        <Button fx:id="browseButton" mnemonicParsing="false" text="&#x53c2;&#x7167;&#x2026;"
                onAction="#onBrowseButtonAction"/>
    </HBox>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Label text="&#x30b7;&#x30fc;&#x30c8;"/>
        <TextField fx:id="sheetField" HBox.hgrow="ALWAYS"/>
    </HBox>
    <HBox spacing="8.0">
        <Button fx:id="loadButton" mnemonicParsing="false" text="&#x8aad;&#x8fbc;"
                onAction="#onLoadButtonAction"/>
    </HBox>
    <HBox fx:id="columnStripHostRow" alignment="CENTER_LEFT" spacing="8.0"
          style="-fx-alignment: CENTER_LEFT;">
        <HBox fx:id="columnStripHost" spacing="0.0"/>
        <Label text="&#x5217;&#x5e45;(px)"/>
        <TextField fx:id="colWidthField" maxWidth="72.0" prefWidth="72.0" promptText="112"/>
    </HBox>
    <TableView fx:id="table" minHeight="240.0" VBox.vgrow="ALWAYS">
        <VBox.margin>
            <Insets bottom="8.0" left="8.0" right="8.0"/>
        </VBox.margin>
    </TableView>
</VBox>
