<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<!-- 結果_配台表.json: ControlsFX SpreadsheetView in {@link ResultDispatchTableTabController}. -->
<VBox xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="jp.co.pm.ai.desktop.ResultDispatchTableTabController" fillWidth="true" spacing="8.0">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
    </padding>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <padding>
            <Insets bottom="4.0"/>
        </padding>
        <Button fx:id="refreshButton" mnemonicParsing="false" text="再読み"
                onAction="#onRefreshButtonAction"/>
        <Button mnemonicParsing="false" text="列フィルタ・並べ替え解除"
                onAction="#onClearColumnFiltersAction"/>
        <Label fx:id="statusLabel"/>
    </HBox>
    <Label fx:id="pathLabel" wrapText="true"/>
    <Label fx:id="hintLabel" wrapText="true"/>
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="データ行の高さ（一括）"/>
        <Slider fx:id="resultDispatchRowHeightSlider" blockIncrement="25.0" majorTickUnit="250.0" max="2000.0" min="50.0"
                prefWidth="240.0" showTickMarks="true"/>
        <Label fx:id="resultDispatchRowHeightPctLabel" minWidth="52.0" text="100%"/>
        <CheckBox fx:id="resultDispatchCellWrapCheck" mnemonicParsing="false" text="長い文字列を折り返す"/>
    </HBox>
    <HBox fx:id="columnStripHost" spacing="0.0"/>
    <StackPane fx:id="spreadsheetHost" minHeight="240.0" VBox.vgrow="ALWAYS"/>
    <VBox spacing="4.0">
        <VBox.margin>
            <Insets top="8.0"/>
        </VBox.margin>
        <Label text="メタ情報"/>
        <Text fx:id="metaText" wrappingWidth="880.0"/>
    </VBox>
</VBox>
