<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<!-- UI 文言は UTF-8 の日本語リテラル（XML 宣言の encoding と一致）。 -->
<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            styleClass="pm-shell"
            prefWidth="1800.0" prefHeight="850.0"
            fx:controller="jp.co.pm.ai.desktop.MainShellController">
    <top>
        <ToolBar styleClass="pm-app-toolbar">
            <Label text="テーマ"/>
            <ComboBox fx:id="themeCombo" prefWidth="196.0"/>
            <Separator orientation="VERTICAL"/>
            <HBox fx:id="shellStageProgressBox" alignment="CENTER_LEFT" managed="false" spacing="8.0" styleClass="pm-shell-stage-progress" visible="false">
                <Label fx:id="shellStageProgressLabel" minWidth="130.0" text="" />
                <ProgressIndicator fx:id="shellStageBusyIndicator" managed="false" prefHeight="22.0" prefWidth="22.0" visible="false" />
                <ProgressBar fx:id="shellStageProgressBar" managed="false" maxWidth="Infinity" prefWidth="220.0" visible="false" />
                <Button fx:id="shellStageCancelButton" managed="false" mnemonicParsing="false" onAction="#onCancelStageRunAction" text="中断" visible="false" />
            </HBox>
            <Region fx:id="toolbarGrowSpacer" maxWidth="Infinity" minWidth="0.0" />
            <Label fx:id="jvmMemoryStatusLabel" styleClass="pm-jvm-memory-status" text="Memory: ..." />
        </ToolBar>
    </top>
    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" tabDragPolicy="REORDER">
            <tabs>
                <Tab fx:id="mainShellTabRun" closable="false" text="実行・ログ">
                    <content>
                        <fx:include fx:id="mainRunTab" source="MainRunTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabUiBadgeDesign" closable="false" text="UIバッジ">
                    <content>
                        <fx:include fx:id="uiBadgeDesignTab" source="UiBadgeDesignTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabPushButtonDesign" closable="false" text="プッシュボタン">
                    <content>
                        <fx:include fx:id="pushButtonDesignTab" source="PushButtonDesignTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabEnv" closable="false" text="環境変数">
                    <content>
                        <fx:include fx:id="envTab" source="EnvTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabMemorySettings" closable="false" text="メモリ設定">
                    <content>
                        <fx:include fx:id="memorySettingsTab" source="MemorySettingsTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabMasterSummary" closable="false"
                     text="マスタ読込サマリ">
                    <content>
                        <fx:include fx:id="masterReadSummaryTab" source="MasterReadSummaryTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabPlanInput" closable="false"
                     text="配台計画_タスク入力">
                    <content>
                        <fx:include fx:id="planInputTab" source="PlanInputTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabStage1Preview" closable="false"
                     text="段階1 成形結果">
                    <content>
                        <fx:include fx:id="stage1PreviewTab" source="Stage1PreviewTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabExcludeRules" closable="false"
                     text="配台不要ルール (JSON)">
                    <content>
                        <fx:include fx:id="excludeRulesTab" source="ExcludeRulesTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabSpecialRules" closable="false"
                     text="特別ルール">
                    <content>
                        <fx:include fx:id="specialRulesTab" source="SpecialRulesTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabActualsStatus" closable="false"
                     text="実績DATA・明細の取得状態">
                    <content>
                        <fx:include fx:id="actualsStatusTab" source="ActualsStatusTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabResultDispatch" closable="false"
                     text="結果_配台表 (JSON)">
                    <content>
                        <fx:include fx:id="resultDispatchTableTab" source="ResultDispatchTableTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabDispatchInteractive" closable="false"
                     text="配台計画手動修正">
                    <content>
                        <fx:include fx:id="dispatchInteractiveTab" source="DispatchInteractiveTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabPlanResultViewer" closable="false"
                     text="計画結果ビューア (JSON)">
                    <content>
                        <fx:include fx:id="planResultViewerTab" source="PlanResultViewerTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabEquipmentGanttGraphic" closable="false"
                     text="設備ガント（グラフィック）">
                    <content>
                        <fx:include fx:id="equipmentGanttGraphicTab" source="EquipmentGanttGraphicTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabGanttPersonBadgeDesign" closable="false"
                     text="設備ガント・担当バッジ">
                    <content>
                        <fx:include fx:id="ganttPersonBadgeDesignTab" source="GanttPersonBadgeDesignTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabOperatorCard" closable="false"
                     text="オペレーターカード">
                    <content>
                        <fx:include fx:id="operatorCardTab" source="OperatorCardTab.fxml"/>
                    </content>
                </Tab>
                <Tab fx:id="mainShellTabOrganizer" closable="false" text="タブ整理">
                    <content>
                        <fx:include fx:id="mainShellTabOrganizerPane" source="MainShellTabOrganizerTab.fxml"/>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>
