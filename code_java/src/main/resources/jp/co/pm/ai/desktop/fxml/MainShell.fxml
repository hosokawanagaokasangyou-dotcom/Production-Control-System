<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>

<!-- Japanese tab titles as numeric refs so file stays valid UTF-8 ASCII (avoids mojibake on Windows tools). -->
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jp.co.pm.ai.desktop.MainShellController">
    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab closable="false" text="&#x5b9f;&#x884c;&#x30fb;&#x30ed;&#x30b0;">
                    <content>
                        <fx:include fx:id="mainRunTab" source="MainRunTab.fxml"/>
                    </content>
                </Tab>
                <Tab closable="false" text="&#x74b0;&#x5883;&#x5909;&#x6570;">
                    <content>
                        <fx:include fx:id="envTab" source="EnvTab.fxml"/>
                    </content>
                </Tab>
                <Tab closable="false" text="&#x30b0;&#x30e9;&#x30d5; (JFreeChart)">
                    <content>
                        <fx:include fx:id="chartTab" source="ChartTab.fxml"/>
                    </content>
                </Tab>
                <Tab closable="false"
                     text="&#x914d;&#x53f0;&#x8a08;&#x753b;_&#x30bf;&#x30b9;&#x30af;&#x5165;&#x529b;">
                    <content>
                        <BorderPane fx:id="planInputHost"/>
                    </content>
                </Tab>
                <Tab closable="false" text="&#x6bb5;&#x968e;1 &#x6210;&#x5f62;&#x7d50;&#x679c;">
                    <content>
                        <BorderPane fx:id="stage1Host"/>
                    </content>
                </Tab>
                <Tab closable="false" text="&#x914d;&#x53f0;&#x4e0d;&#x8981;&#x30eb;&#x30fc;&#x30eb; (JSON)">
                    <content>
                        <BorderPane fx:id="excludeRulesHost"/>
                    </content>
                </Tab>
                <Tab closable="false"
                     text="&#x5b9f;&#x7e3e;DATA&#x30fb;&#x660e;&#x7d30;&#x306e;&#x53d6;&#x5f97;&#x72b6;&#x614b;">
                    <content>
                        <BorderPane fx:id="actualsHost"/>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>
