<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="jp.co.pm.ai.desktop.MasterReadSummaryTabController"
      spacing="8.0">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <children>
        <ToolBar>
            <items>
                <Button fx:id="refreshButton" mnemonicParsing="false"
                        text="サマリを更新"
                        onAction="#onRefreshAction"/>
                <Button fx:id="openExcelButton" mnemonicParsing="false"
                        text="Excelで開く"
                        onAction="#onOpenExcelAction"/>
                <Button fx:id="copyJsonButton" mnemonicParsing="false"
                        text="クリップボード（JSON）"
                        onAction="#onCopyJsonAction"/>
            </items>
        </ToolBar>
        <Label fx:id="statusLabel" styleClass="master-summary-status" text=""/>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
            <VBox fx:id="contentBox" spacing="10.0">
                <padding>
                    <Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
                </padding>
                <Label style="-fx-font-weight: bold;"
                       text="ファイル"/>
                <TextField fx:id="resolvedPathField" editable="false"/>
                <HBox spacing="16.0">
                    <Label fx:id="fileExistsLabel" text=""/>
                    <Label fx:id="cwdLabel" text=""/>
                </HBox>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="環境・speed"/>
                <GridPane fx:id="envGrid" hgap="8.0" vgap="4.0"/>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="skills / need（実読み込み）"/>
                <GridPane fx:id="skillsNeedGrid" hgap="8.0" vgap="4.0"/>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="組み合わせ表（プリセット）"/>
                <GridPane fx:id="teamComboGrid" hgap="8.0" vgap="4.0"/>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="メインシート（工場枢・定常）"/>
                <GridPane fx:id="mainGrid" hgap="8.0" vgap="4.0"/>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="シート確認"/>
                <TableView fx:id="sheetTable" prefHeight="200.0" minHeight="120.0">
                    <columns>
                        <TableColumn fx:id="colCategory" text="区分" prefWidth="140.0"/>
                        <TableColumn fx:id="colSheetName" text="シート名" prefWidth="200.0"/>
                        <TableColumn fx:id="colPresent" text="状態" prefWidth="72.0"/>
                        <TableColumn fx:id="colNote" text="備考" prefWidth="120.0"/>
                    </columns>
                </TableView>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="設定シート（マスタ内・読み）"/>
                <GridPane fx:id="appConfigGrid" hgap="8.0" vgap="4.0"/>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="配台不要工程シート（スキャン）"/>
                <GridPane fx:id="excludeRulesGrid" hgap="8.0" vgap="4.0"/>

                <Label style="-fx-font-weight: bold;"
                       text="配台不要工程（ルール行・マスタ読み JSON）"/>
                <TableView fx:id="excludeRulesSampleTable" prefHeight="200.0" minHeight="120.0">
                    <columns>
                        <TableColumn fx:id="colExProcess" text="工程名" prefWidth="148.0"/>
                        <TableColumn fx:id="colExMachine" text="機械名" prefWidth="148.0"/>
                        <TableColumn fx:id="colExFlag" text="配台不要" prefWidth="88.0"/>
                        <TableColumn fx:id="colExParsed" text="ロジック式（要約）" prefWidth="260.0"/>
                    </columns>
                </TableView>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="論理定数・範囲"/>
                <GridPane fx:id="planningConstantsGrid" hgap="8.0" vgap="4.0"/>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="詳細テーブル（speed / need / 占有日）"/>
                <TableView fx:id="speedSampleTable" prefHeight="160.0" minHeight="100.0">
                    <columns>
                        <TableColumn fx:id="colSpeedProcess" text="工程（正規化）" prefWidth="160.0"/>
                        <TableColumn fx:id="colSpeedMachine" text="機械（正規化）" prefWidth="160.0"/>
                        <TableColumn fx:id="colSpeedMpm" text="m/分" prefWidth="88.0"/>
                    </columns>
                </TableView>
                <TableView fx:id="needBaseTable" prefHeight="140.0" minHeight="80.0">
                    <columns>
                        <TableColumn fx:id="colNeedCombo" text="工程+機械" prefWidth="260.0"/>
                        <TableColumn fx:id="colNeedReq" text="基本必需" prefWidth="96.0"/>
                    </columns>
                </TableView>
                <TableView fx:id="needRulesTable" prefHeight="140.0" minHeight="80.0">
                    <columns>
                        <TableColumn fx:id="colRuleOrder" text="特別指定" prefWidth="88.0"/>
                        <TableColumn fx:id="colRuleCond" text="条件（先頭）" prefWidth="280.0"/>
                        <TableColumn fx:id="colRuleOv" text="上書き件数" prefWidth="96.0"/>
                    </columns>
                </TableView>
                <TableView fx:id="calendarTopDatesTable" prefHeight="120.0" minHeight="72.0">
                    <columns>
                        <TableColumn fx:id="colCalDate" text="日付" prefWidth="120.0"/>
                        <TableColumn fx:id="colCalIv" text="区間数" prefWidth="88.0"/>
                    </columns>
                </TableView>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="ブック内全シート名"/>
                <ListView fx:id="allSheetsList" prefHeight="180.0" minHeight="100.0"/>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="機械カレンダー・日次始業等"/>
                <GridPane fx:id="machineCalendarGrid" hgap="8.0" vgap="4.0"/>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="勤怠（候補）"/>
                <GridPane fx:id="attendanceGrid" hgap="8.0" vgap="4.0"/>
                <Label style="-fx-font-weight: bold;"
                       text="勤怠候補シート名（メンバー一致）"/>
                <ListView fx:id="attendanceSheetsList" prefHeight="140.0" minHeight="72.0"/>

                <Separator/>

                <Label style="-fx-font-weight: bold;"
                       text="警告・注意"/>
                <ListView fx:id="warningsList" prefHeight="120.0" minHeight="80.0"/>
            </VBox>
        </ScrollPane>
    </children>
</VBox>
