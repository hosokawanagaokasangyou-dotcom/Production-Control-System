<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="jp.co.pm.ai.desktop.DeliveryCalendarViewTabController"
      fillWidth="true" spacing="8.0">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
    </padding>
    <HBox alignment="CENTER_LEFT" spacing="8.0">
        <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#onRefreshButtonAction"
                text="&#x518d;&#x8aad;&#x8fbc;"/>
        <Label fx:id="statusLabel"/>
    </HBox>
    <VBox fx:id="deliveryReloadProgressContainer" managed="false" spacing="3.0" visible="false">
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label minWidth="130.0" style="-fx-font-size: 11px;" text="ペイロード準備"/>
            <ProgressBar fx:id="deliveryReloadProgressPayloadPrep" maxWidth="Infinity" prefHeight="12.0"
                         HBox.hgrow="ALWAYS"/>
            <Label fx:id="deliveryReloadPctPayloadPrep" minWidth="38.0" style="-fx-font-size: 11px;" text="0%"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label minWidth="130.0" style="-fx-font-size: 11px;" text="アラジン加工計画"/>
            <ProgressBar fx:id="deliveryReloadProgressAladdin" maxWidth="Infinity" prefHeight="12.0"
                         HBox.hgrow="ALWAYS"/>
            <Label fx:id="deliveryReloadPctAladdin" minWidth="38.0" style="-fx-font-size: 11px;" text="0%"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label minWidth="130.0" style="-fx-font-size: 11px;" text="加工実績"/>
            <ProgressBar fx:id="deliveryReloadProgressActuals" maxWidth="Infinity" prefHeight="12.0"
                         HBox.hgrow="ALWAYS"/>
            <Label fx:id="deliveryReloadPctActuals" minWidth="38.0" style="-fx-font-size: 11px;" text="0%"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label minWidth="130.0" style="-fx-font-size: 11px;" text="配台結果"/>
            <ProgressBar fx:id="deliveryReloadProgressDispatch" maxWidth="Infinity" prefHeight="12.0"
                         HBox.hgrow="ALWAYS"/>
            <Label fx:id="deliveryReloadPctDispatch" minWidth="38.0" style="-fx-font-size: 11px;" text="0%"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <Label minWidth="130.0" style="-fx-font-size: 11px;" text="メイン表"/>
            <ProgressBar fx:id="deliveryReloadProgressMainCalendar" maxWidth="Infinity" prefHeight="12.0"
                         HBox.hgrow="ALWAYS"/>
            <Label fx:id="deliveryReloadPctMainCalendar" minWidth="38.0" style="-fx-font-size: 11px;" text="0%"/>
        </HBox>
    </VBox>
    <Accordion VBox.vgrow="NEVER">
        <panes>
            <TitledPane animated="false" expanded="false" text="&#x30e1;&#x30bf;&#x60c5;&#x5831;">
                <content>
                    <VBox fillWidth="true" spacing="4.0">
                        <ScrollPane fx:id="metaScrollPane" fitToWidth="true" hbarPolicy="NEVER"
                                    maxHeight="320.0" minViewportHeight="96.0"
                                    prefViewportHeight="220.0"
                                    style="-fx-background-color: transparent;">
                            <Label fx:id="metaLabel" wrapText="true"
                                   style="-fx-line-spacing: 10px; -fx-padding: 6 8 10 8;"/>
                        </ScrollPane>
                    </VBox>
                </content>
            </TitledPane>
        </panes>
    </Accordion>
    <TabPane fx:id="innerTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab closable="false" text="&#x30a2;&#x30e9;&#x30fb;&#x5b9f;&#x7e3e;&#x30fb;&#x30b7;&#x30b9;&#x6bd4;&#x8f03;">
                <content>
                    <VBox fillWidth="true" maxHeight="Infinity" spacing="8.0">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
                        </padding>
                        <TitledPane animated="true" expanded="true"
                                    text="&#x64cd;&#x4f5c;&#x30fb;&#x30bd;&#x30fc;&#x30b9;">
                            <content>
                                <VBox fillWidth="true" spacing="8.0">
                                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                                        <padding>
                                            <Insets bottom="4.0"/>
                                        </padding>
                                        <Button fx:id="mainClearFiltersButton" mnemonicParsing="false"
                                                onAction="#onClearMainFilters"
                                                text="&#x5217;&#x30d5;&#x30a3;&#x30eb;&#x30bf;&#x30fb;&#x4e26;&#x3079;&#x66ff;&#x3048;&#x89e3;&#x9664;"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                        <Label text="&#x30c7;&#x30fc;&#x30bf;&#x884c;&#x306e;&#x9ad8;&#x3055;&#xff08;&#x4e00;&#x62ec;&#xff09;"/>
                                        <Slider fx:id="mainRowHeightSlider" blockIncrement="25.0"
                                                majorTickUnit="250.0" max="2000.0" min="50.0"
                                                prefWidth="240.0" showTickMarks="true"/>
                                        <Label fx:id="mainRowHeightPctLabel" minWidth="52.0" text="100%"/>
                                        <CheckBox fx:id="mainCellWrapCheck" mnemonicParsing="false"
                                                  text="&#x9577;&#x3044;&#x6587;&#x5b57;&#x5217;&#x3092;&#x6298;&#x308a;&#x8fd4;&#x3059;"/>
                                    </HBox>
                                    <HBox fx:id="mainColumnStripHost" spacing="0.0"/>
                                </VBox>
                            </content>
                        </TitledPane>
                        <TitledPane animated="true" expanded="true" maxHeight="Infinity"
                                    text="&#x30c7;&#x30fc;&#x30bf;&#x8868;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fillWidth="true" maxHeight="Infinity">
                                    <StackPane fx:id="mainSpreadsheetHost" minHeight="240.0" VBox.vgrow="ALWAYS"/>
                                </VBox>
                            </content>
                        </TitledPane>
                    </VBox>
                </content>
            </Tab>
            <Tab closable="false" text="&#x914d;&#x53f0;&#x7d50;&#x679c;">
                <content>
                    <fx:include fx:id="deliveryCalendarResultDispatchTableTab"
                                source="ResultDispatchTableTab.fxml"/>
                </content>
            </Tab>
            <Tab closable="false" text="&#x52a0;&#x5de5;&#x5b9f;&#x7e3e;">
                <content>
                    <fx:include fx:id="processingActualsDataTab" source="ProcessingActualsDataTab.fxml"/>
                </content>
            </Tab>
            <Tab closable="false"
                 text="&#x30a2;&#x30e9;&#x30b8;&#x30f3;&#x52a0;&#x5de5;&#x8a08;&#x753b;&#x53d6;&#x5f97;&#x30c7;&#x30fc;&#x30bf;">
                <content>
                    <fx:include fx:id="aladdinProcessingPlanDataTab" source="AladdinProcessingPlanDataTab.fxml"/>
                </content>
            </Tab>
        </tabs>
    </TabPane>
</VBox>
