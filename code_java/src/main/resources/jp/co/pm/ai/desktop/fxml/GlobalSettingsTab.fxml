<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jp.co.pm.ai.desktop.GlobalSettingsTabController">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
    </padding>
    <center>
        <VBox spacing="12.0">
            <Label style="-fx-font-weight: bold" text="グローバル設定"/>
            <Label wrapText="true" maxWidth="720"
                   text="タブの並び・各表の列・テーマ・ガント表示など UI の「工場出荷の既定」への復帰と、パッケージ用既定ファイル（リポジトリの init_setting）への書き出しを行います。"/>
            <Separator/>
            <Label style="-fx-font-weight: bold" text="init_setting の対象工場"/>
            <Label wrapText="true" maxWidth="720" style="-fx-text-fill: -fx-mid-text-color"
                   text="「デフォルトに戻す」と「現在の状態をデフォルトとする」で読み書きする JSON は、湖南工場用と国分工場用でファイル名が分かれます（例: session_defaults_kokubu.json）。環境タブの工場プリセット適用時もこの選択は自動で追随します（ここで変更してもよい）。"/>
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label text="対象工場:"/>
                <ComboBox fx:id="initSettingTargetCombo" prefWidth="220.0"/>
            </HBox>
            <Separator/>
            <Button fx:id="resetUiButton" mnemonicParsing="false" onAction="#onResetUiToFactoryAction"
                    text="デフォルトに戻す"/>
            <Label wrapText="true" maxWidth="720" style="-fx-text-fill: -fx-mid-text-color"
                   text="環境変数タブはテンプレ既定へ戻ります。実行タブのタスク入力ブック等のパスはその時点の値が維持されます。リポジトリ init_setting に「現在の状態をデフォルトとする」で書き出した JSON があるときは、可能な範囲でその内容へ復帰します（無い場合はバンドル既定）。 ~/.pm-ai-desktop の列順・一部 JSON は削除されます。"/>
            <Separator/>
            <Button fx:id="saveDefaultsButton" mnemonicParsing="false" onAction="#onSavePackageDefaultsAction"
                    text="現在の状態をデフォルトとする"/>
            <Label wrapText="true" maxWidth="720" style="-fx-text-fill: -fx-mid-text-color"
                   text="リポジトリ直下の init_setting に、上で選んだ工場向けの session_defaults_*.json と table_column_defaults_*.json を書き出します（従来の単一名の JSON が残っていても、工場別ファイルがあればそちらが「デフォルトに戻す」の最終層として優先されます）。確認のためダイアログで「111」を入力する必要があります。"/>
        </VBox>
    </center>
</BorderPane>
