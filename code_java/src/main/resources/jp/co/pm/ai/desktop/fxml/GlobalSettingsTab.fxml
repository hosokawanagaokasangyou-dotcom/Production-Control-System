<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jp.co.pm.ai.desktop.GlobalSettingsTabController">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
    </padding>
    <center>
        <VBox spacing="12.0">
            <Label style="-fx-font-weight: bold" text="グローバル設定"/>
            <Label wrapText="true" maxWidth="720"
                   text="タブの並び・各表の列・テーマ・ガント表示など UI の「工場出荷の既定」への復帰と、パッケージ用既定ファイル（リポジトリの init_setting）への書き出しを行います。"/>
            <Separator/>
            <Button fx:id="resetUiButton" mnemonicParsing="false" onAction="#onResetUiToFactoryAction"
                    text="デフォルトに戻す"/>
            <Label wrapText="true" maxWidth="720" style="-fx-text-fill: -fx-mid-text-color"
                   text="環境変数タブはテンプレ既定へ戻ります。実行タブのパス・Python はその時点の値が維持されます（セッションの UI キーのみバンドル既定へ）。 ~/.pm-ai-desktop の列順・一部 JSON は削除されます。"/>
            <Separator/>
            <Button fx:id="saveDefaultsButton" mnemonicParsing="false" onAction="#onSavePackageDefaultsAction"
                    text="現在の状態をデフォルトとする"/>
            <Label wrapText="true" maxWidth="720" style="-fx-text-fill: -fx-mid-text-color"
                   text="リポジトリ直下の init_setting に session_defaults.json と table_column_defaults.json を書き出します。確認のためダイアログで「111」を入力する必要があります。"/>
        </VBox>
    </center>
</BorderPane>
