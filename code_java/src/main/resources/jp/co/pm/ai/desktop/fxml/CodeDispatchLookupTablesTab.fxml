<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="jp.co.pm.ai.desktop.CodeDispatchLookupTablesTabController">
    <center>
        <VBox spacing="8.0">
            <padding>
                <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
            </padding>
            <Label fx:id="hintLabel" wrapText="true"/>
            <TabPane fx:id="fileTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
