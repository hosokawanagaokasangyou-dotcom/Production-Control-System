<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <!-- ASCII-only: avoid XML parse failures on Windows when file encoding differs from UTF-8. -->
  <!-- log4j-core is required (see pom). RegexFilter suppresses POI "Skipped invalid entry ... sharedStrings.xml". -->
  <!-- Remove RegexFilter temporarily if you need to debug workbook OPC issues; re-save xlsx in Excel if corrupt. -->
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <RegexFilter regex=".*Skipped invalid entry /xl/sharedStrings\.xml.*"
                   onMatch="DENY"
                   onMismatch="NEUTRAL"/>
      <PatternLayout charset="UTF-8"
                     pattern="%d{ISO8601}{UTC} %t %-5level %logger{36} - %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <Root level="info">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
