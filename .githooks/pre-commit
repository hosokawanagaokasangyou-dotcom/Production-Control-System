#!/bin/sh
# Bump code/version.txt by +0.1 via PowerShell. Disable: SKIP_BUMP_CODE_VERSION=1
if [ "$SKIP_BUMP_CODE_VERSION" = "1" ]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

if [ ! -f "code/version.txt" ]; then
  exit 0
fi

if ! command -v powershell >/dev/null 2>&1; then
  echo "pre-commit: powershell not found; skip version bump" >&2
  exit 0
fi

powershell -NoProfile -ExecutionPolicy Bypass -File "$ROOT/scripts/bump_code_version_txt.ps1" || exit 1
git add "code/version.txt" || exit 1
